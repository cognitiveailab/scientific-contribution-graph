    "__edge_metadata_53" [label=<
<TABLE BORDER="0" CELLBORDER="0" CELLPADDING="4">
<TR><TD ALIGN="LEFT"><B><FONT POINT-SIZE="10">Prerequisite Edge Description</FONT></B></TD></TR>
<TR><TD ALIGN="LEFT"><FONT POINT-SIZE="9" COLOR="gray35"><B>Description:</B></FONT><BR ALIGN="LEFT"/><FONT POINT-SIZE="9">Existing work on entailment‑tree generation in pure<BR ALIGN="LEFT"/>NLP, notably the EntailmentBank dataset and subsequent<BR ALIGN="LEFT"/>models that generate multi‑step logical trees from<BR ALIGN="LEFT"/>textual premises and a hypothesis.</FONT></TD></TR>
<TR><TD ALIGN="LEFT"><FONT POINT-SIZE="9" COLOR="gray35"><B>Explanation:</B></FONT><BR ALIGN="LEFT"/><FONT POINT-SIZE="9">The new multimodal task builds directly on the<BR ALIGN="LEFT"/>definition, data format, and evaluation concepts<BR ALIGN="LEFT"/>introduced by these prior works.</FONT></TD></TR>
<TR><TD ALIGN="LEFT"><FONT POINT-SIZE="10">strength: strong; depth: 0</FONT></TD></TR>
</TABLE>
>, shape=box, style="rounded,filled,dashed", color="gray60", fillcolor="#e8f4ea", fontname="Helvetica", margin="0.04,0.03"];
    "273641238.c1" -> "__edge_metadata_53" [dir=none, weight=3];
    "__edge_metadata_53" -> "233297051.c0" [weight=3];
    "__edge_metadata_54" [label=<
<TABLE BORDER="0" CELLBORDER="0" CELLPADDING="4">
<TR><TD ALIGN="LEFT"><B><FONT POINT-SIZE="10">Prerequisite Edge Description</FONT></B></TD></TR>
<TR><TD ALIGN="LEFT"><FONT POINT-SIZE="9" COLOR="gray35"><B>Description:</B></FONT><BR ALIGN="LEFT"/><FONT POINT-SIZE="9">The overall formulation that structures multimodal<BR ALIGN="LEFT"/>reasoning as a tree whose leaves are selected premises<BR ALIGN="LEFT"/>(facts) and internal nodes are intermediate<BR ALIGN="LEFT"/>conclusions generated by an LLM, with the original<BR ALIGN="LEFT"/>question as the root hypothesis.</FONT></TD></TR>
<TR><TD ALIGN="LEFT"><FONT POINT-SIZE="9" COLOR="gray35"><B>Explanation:</B></FONT><BR ALIGN="LEFT"/><FONT POINT-SIZE="9">Ablation removes the explicit entailment‑tree<BR ALIGN="LEFT"/>generation step to assess its benefit for reasoning<BR ALIGN="LEFT"/>and interpretability.</FONT></TD></TR>
<TR><TD ALIGN="LEFT"><FONT POINT-SIZE="10">strength: strong; depth: 0</FONT></TD></TR>
</TABLE>
>, shape=box, style="rounded,filled,dashed", color="gray60", fillcolor="#e8f4ea", fontname="Helvetica", margin="0.04,0.03"];
