    "__edge_metadata_60" [label=<
<TABLE BORDER="0" CELLBORDER="0" CELLPADDING="4">
<TR><TD ALIGN="LEFT"><B><FONT POINT-SIZE="10">Prerequisite Edge Description</FONT></B></TD></TR>
<TR><TD ALIGN="LEFT"><FONT POINT-SIZE="9" COLOR="gray35"><B>Description:</B></FONT><BR ALIGN="LEFT"/><FONT POINT-SIZE="9">Research on constructing inference chains across<BR ALIGN="LEFT"/>multiple textual fragments and measuring performance<BR ALIGN="LEFT"/>degradation as the number of hops increases.</FONT></TD></TR>
<TR><TD ALIGN="LEFT"><FONT POINT-SIZE="9" COLOR="gray35"><B>Explanation:</B></FONT><BR ALIGN="LEFT"/><FONT POINT-SIZE="9">Understanding existing findings on multi‑hop reasoning<BR ALIGN="LEFT"/>is required to recognize it as a distinct difficulty<BR ALIGN="LEFT"/>in NLI4CT.</FONT></TD></TR>
<TR><TD ALIGN="LEFT"><FONT POINT-SIZE="10">strength: strong; depth: 0</FONT></TD></TR>
</TABLE>
>, shape=box, style="rounded,filled,dashed", color="gray60", fillcolor="#e8f4ea", fontname="Helvetica", margin="0.04,0.03"];
    "258480186.c7-1" -> "__edge_metadata_60" [dir=none, weight=3];
    "__edge_metadata_60" -> "233297051.c0" [weight=3];
    "__edge_metadata_61" [label=<
<TABLE BORDER="0" CELLBORDER="0" CELLPADDING="4">
<TR><TD ALIGN="LEFT"><B><FONT POINT-SIZE="10">Prerequisite Edge Description</FONT></B></TD></TR>
<TR><TD ALIGN="LEFT"><FONT POINT-SIZE="9" COLOR="gray35"><B>Description:</B></FONT><BR ALIGN="LEFT"/><FONT POINT-SIZE="9">Entailment trees represent multi‑step logical<BR ALIGN="LEFT"/>derivations where leaf nodes are factual premises and<BR ALIGN="LEFT"/>internal nodes are intermediate conclusions, providing<BR ALIGN="LEFT"/>an interpretable structure for QA explanations.</FONT></TD></TR>
<TR><TD ALIGN="LEFT"><FONT POINT-SIZE="9" COLOR="gray35"><B>Explanation:</B></FONT><BR ALIGN="LEFT"/><FONT POINT-SIZE="9">SEER builds directly on the entailment‑tree formalism<BR ALIGN="LEFT"/>to define its state, actions, and reward alignment.</FONT></TD></TR>
<TR><TD ALIGN="LEFT"><FONT POINT-SIZE="10">strength: strong; depth: 0</FONT></TD></TR>
</TABLE>
>, shape=box, style="rounded,filled,dashed", color="gray60", fillcolor="#e8f4ea", fontname="Helvetica", margin="0.04,0.03"];
    "267199832.c0" -> "__edge_metadata_61" [dir=none, weight=3];
    "__edge_metadata_61" -> "233297051.c0" [weight=3];
    "__edge_metadata_62" [label=<
<TABLE BORDER="0" CELLBORDER="0" CELLPADDING="4">
<TR><TD ALIGN="LEFT"><B><FONT POINT-SIZE="10">Prerequisite Edge Description</FONT></B></TD></TR>
<TR><TD ALIGN="LEFT"><FONT POINT-SIZE="9" COLOR="gray35"><B>Description:</B></FONT><BR ALIGN="LEFT"/><FONT POINT-SIZE="9">Formalizations of multi-step reasoning as hierarchical<BR ALIGN="LEFT"/>trees (entailment trees) or directed acyclic graphs<BR ALIGN="LEFT"/>(reasoning graphs) that capture logical dependencies<BR ALIGN="LEFT"/>between premises and conclusions.</FONT></TD></TR>
<TR><TD ALIGN="LEFT"><FONT POINT-SIZE="9" COLOR="gray35"><B>Explanation:</B></FONT><BR ALIGN="LEFT"/><FONT POINT-SIZE="9">The return is defined over parent nodes in these<BR ALIGN="LEFT"/>structures; thus a clear definition of the tree/graph<BR ALIGN="LEFT"/>format is required.</FONT></TD></TR>
<TR><TD ALIGN="LEFT"><FONT POINT-SIZE="10">strength: strong; depth: 0</FONT></TD></TR>
</TABLE>
>, shape=box, style="rounded,filled,dashed", color="gray60", fillcolor="#e8f4ea", fontname="Helvetica", margin="0.04,0.03"];
    "267199832.c1" -> "__edge_metadata_62" [dir=none, weight=3];
    "__edge_metadata_62" -> "233297051.c0" [weight=3];
    "__edge_metadata_63" [label=<
<TABLE BORDER="0" CELLBORDER="0" CELLPADDING="4">
<TR><TD ALIGN="LEFT"><B><FONT POINT-SIZE="10">Prerequisite Edge Description</FONT></B></TD></TR>
<TR><TD ALIGN="LEFT"><FONT POINT-SIZE="9" COLOR="gray35"><B>Description:</B></FONT><BR ALIGN="LEFT"/><FONT POINT-SIZE="9">Formalizations of multi‑step explanations as<BR ALIGN="LEFT"/>hierarchical trees or directed graphs where leaves are<BR ALIGN="LEFT"/>facts, internal nodes are intermediate conclusions,<BR ALIGN="LEFT"/>and the root is the hypothesis.</FONT></TD></TR>
<TR><TD ALIGN="LEFT"><FONT POINT-SIZE="9" COLOR="gray35"><B>Explanation:</B></FONT><BR ALIGN="LEFT"/><FONT POINT-SIZE="9">Designing a reward that distinguishes step types<BR ALIGN="LEFT"/>requires a clear definition of the underlying<BR ALIGN="LEFT"/>structured reasoning format.</FONT></TD></TR>
<TR><TD ALIGN="LEFT"><FONT POINT-SIZE="10">strength: strong; depth: 0</FONT></TD></TR>
</TABLE>
>, shape=box, style="rounded,filled,dashed", color="gray60", fillcolor="#e8f4ea", fontname="Helvetica", margin="0.04,0.03"];
    "267199832.c2" -> "__edge_metadata_63" [dir=none, weight=3];
    "__edge_metadata_63" -> "233297051.c0" [weight=3];
    "__edge_metadata_64" [label=<
<TABLE BORDER="0" CELLBORDER="0" CELLPADDING="4">
<TR><TD ALIGN="LEFT"><B><FONT POINT-SIZE="10">Prerequisite Edge Description</FONT></B></TD></TR>
<TR><TD ALIGN="LEFT"><FONT POINT-SIZE="9" COLOR="gray35"><B>Description:</B></FONT><BR ALIGN="LEFT"/><FONT POINT-SIZE="9">Formal definition of the problem where a hypothesis<BR ALIGN="LEFT"/>must be explained by a hierarchical (tree) or<BR ALIGN="LEFT"/>graph‑structured set of inference steps connecting<BR ALIGN="LEFT"/>facts to the hypothesis.</FONT></TD></TR>
<TR><TD ALIGN="LEFT"><FONT POINT-SIZE="9" COLOR="gray35"><B>Explanation:</B></FONT><BR ALIGN="LEFT"/><FONT POINT-SIZE="9">Converting the task into single‑step supervised<BR ALIGN="LEFT"/>examples relies on this formalization.</FONT></TD></TR>
<TR><TD ALIGN="LEFT"><FONT POINT-SIZE="10">strength: strong; depth: 0</FONT></TD></TR>
</TABLE>
>, shape=box, style="rounded,filled,dashed", color="gray60", fillcolor="#e8f4ea", fontname="Helvetica", margin="0.04,0.03"];
    "267199832.c3" -> "__edge_metadata_64" [dir=none, weight=3];
    "__edge_metadata_64" -> "233297051.c0" [weight=3];
    "__edge_metadata_65" [label=<
<TABLE BORDER="0" CELLBORDER="0" CELLPADDING="4">
<TR><TD ALIGN="LEFT"><B><FONT POINT-SIZE="10">Prerequisite Edge Description</FONT></B></TD></TR>
<TR><TD ALIGN="LEFT"><FONT POINT-SIZE="9" COLOR="gray35"><B>Description:</B></FONT><BR ALIGN="LEFT"/><FONT POINT-SIZE="9">A structured proof‑generation setting where a claim is<BR ALIGN="LEFT"/>proved by iteratively combining premise statements<BR ALIGN="LEFT"/>into intermediate deductions, formalized in the<BR ALIGN="LEFT"/>EntailmentBank dataset and supported by entailment<BR ALIGN="LEFT"/>models trained on the WaNLI benchmark.</FONT></TD></TR>
<TR><TD ALIGN="LEFT"><FONT POINT-SIZE="9" COLOR="gray35"><B>Explanation:</B></FONT><BR ALIGN="LEFT"/><FONT POINT-SIZE="9">The notion of a valid deduction d_{ab} and the overall<BR ALIGN="LEFT"/>proof‑generation task that motivates DA rely on this<BR ALIGN="LEFT"/>entailment‑tree formulation.</FONT></TD></TR>
<TR><TD ALIGN="LEFT"><FONT POINT-SIZE="10">strength: strong; depth: 0</FONT></TD></TR>
</TABLE>
>, shape=box, style="rounded,filled,dashed", color="gray60", fillcolor="#e8f4ea", fontname="Helvetica", margin="0.04,0.03"];
    "259343907.c0" -> "__edge_metadata_65" [dir=none, weight=3];
