    "__edge_metadata_35" [label=<
<TABLE BORDER="0" CELLBORDER="0" CELLPADDING="4">
<TR><TD ALIGN="LEFT"><B><FONT POINT-SIZE="10">Prerequisite Edge Description</FONT></B></TD></TR>
<TR><TD ALIGN="LEFT"><FONT POINT-SIZE="9" COLOR="gray35"><B>Description:</B></FONT><BR ALIGN="LEFT"/><FONT POINT-SIZE="9">A search algorithm that maintains two priority queues<BR ALIGN="LEFT"/>(deductive and abductive fringes) and interleaves<BR ALIGN="LEFT"/>forward‑chaining and backward‑chaining steps, guided<BR ALIGN="LEFT"/>by learned heuristics.</FONT></TD></TR>
<TR><TD ALIGN="LEFT"><FONT POINT-SIZE="9" COLOR="gray35"><B>Explanation:</B></FONT><BR ALIGN="LEFT"/><FONT POINT-SIZE="9">The proposed task is solved by a two‑sided search that<BR ALIGN="LEFT"/>simultaneously expands deductions from premises and<BR ALIGN="LEFT"/>abductions from the goal; this algorithmic idea builds<BR ALIGN="LEFT"/>on earlier heuristic search for entailment trees and<BR ALIGN="LEFT"/>classic backward‑chaining concepts.</FONT></TD></TR>
<TR><TD ALIGN="LEFT"><FONT POINT-SIZE="10">strength: strong, weak; depth: 1</FONT></TD></TR>
</TABLE>
>, shape=box, style="rounded,filled,dashed", color="gray60", fillcolor="#eef2f7", fontname="Helvetica", margin="0.04,0.03"];
