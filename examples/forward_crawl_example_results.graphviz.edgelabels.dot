    "__edge_metadata_34" [label=<
<TABLE BORDER="0" CELLBORDER="0" CELLPADDING="4">
<TR><TD ALIGN="LEFT"><B><FONT POINT-SIZE="10">Prerequisite Edge Description</FONT></B></TD></TR>
<TR><TD ALIGN="LEFT"><FONT POINT-SIZE="9" COLOR="gray35"><B>Description:</B></FONT><BR ALIGN="LEFT"/><FONT POINT-SIZE="9">Earlier systems such as EntailmentWriter, ProofWriter,<BR ALIGN="LEFT"/>and NLProlog that introduced entailment trees and<BR ALIGN="LEFT"/>proof‑search over natural language statements.</FONT></TD></TR>
<TR><TD ALIGN="LEFT"><FONT POINT-SIZE="9" COLOR="gray35"><B>Explanation:</B></FONT><BR ALIGN="LEFT"/><FONT POINT-SIZE="9">The conceptual motivation for SCSEARCH builds on these<BR ALIGN="LEFT"/>prior approaches to structured reasoning.</FONT></TD></TR>
<TR><TD ALIGN="LEFT"><FONT POINT-SIZE="10">strength: strong; depth: 0</FONT></TD></TR>
</TABLE>
>, shape=box, style="rounded,filled,dashed", color="gray60", fillcolor="#e8f4ea", fontname="Helvetica", margin="0.04,0.03"];
