    "__edge_metadata_72" [label=<
<TABLE BORDER="0" CELLBORDER="0" CELLPADDING="4">
<TR><TD ALIGN="LEFT"><B><FONT POINT-SIZE="10">Prerequisite Edge Description</FONT></B></TD></TR>
<TR><TD ALIGN="LEFT"><FONT POINT-SIZE="9" COLOR="gray35"><B>Description:</B></FONT><BR ALIGN="LEFT"/><FONT POINT-SIZE="9">Works that investigate guiding language model<BR ALIGN="LEFT"/>reasoning via prompts, entailment trees, and<BR ALIGN="LEFT"/>chain‑of‑thought techniques to obtain more transparent<BR ALIGN="LEFT"/>and controllable outputs.</FONT></TD></TR>
<TR><TD ALIGN="LEFT"><FONT POINT-SIZE="9" COLOR="gray35"><B>Explanation:</B></FONT><BR ALIGN="LEFT"/><FONT POINT-SIZE="9">These studies motivate the need for fine‑grained<BR ALIGN="LEFT"/>control over reasoning steps, which TemplateCSR<BR ALIGN="LEFT"/>addresses through explicit slot constraints.</FONT></TD></TR>
<TR><TD ALIGN="LEFT"><FONT POINT-SIZE="10">strength: strong; depth: 0</FONT></TD></TR>
</TABLE>
>, shape=box, style="rounded,filled,dashed", color="gray60", fillcolor="#e8f4ea", fontname="Helvetica", margin="0.04,0.03"];
