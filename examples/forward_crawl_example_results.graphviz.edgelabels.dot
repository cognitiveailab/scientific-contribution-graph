    "__edge_metadata_12" -> "256846551.c1" [weight=3];
    "__edge_metadata_13" [label=<
<TABLE BORDER="0" CELLBORDER="0" CELLPADDING="4">
<TR><TD ALIGN="LEFT"><B><FONT POINT-SIZE="10">Prerequisite Edge Description</FONT></B></TD></TR>
<TR><TD ALIGN="LEFT"><FONT POINT-SIZE="9" COLOR="gray35"><B>Description:</B></FONT><BR ALIGN="LEFT"/><FONT POINT-SIZE="9">Graph‑based representation of multi‑step reasoning<BR ALIGN="LEFT"/>where nodes contain statements and edges encode<BR ALIGN="LEFT"/>inference relations, originally linearized for LLM<BR ALIGN="LEFT"/>input.</FONT></TD></TR>
<TR><TD ALIGN="LEFT"><FONT POINT-SIZE="9" COLOR="gray35"><B>Explanation:</B></FONT><BR ALIGN="LEFT"/><FONT POINT-SIZE="9">xSTREET retains these graphs from STREET, requiring<BR ALIGN="LEFT"/>the methodology for constructing and preserving them<BR ALIGN="LEFT"/>across languages.</FONT></TD></TR>
<TR><TD ALIGN="LEFT"><FONT POINT-SIZE="10">strength: strong; depth: 2</FONT></TD></TR>
</TABLE>
>, shape=box, style="rounded,filled,dashed", color="gray60", fillcolor="#e8f4ea", fontname="Helvetica", margin="0.04,0.03"];
    "268247756.c0" -> "__edge_metadata_13" [dir=none, weight=3];
    "__edge_metadata_13" -> "256846551.c1" [weight=3];
    "__edge_metadata_14" [label=<
<TABLE BORDER="0" CELLBORDER="0" CELLPADDING="4">
<TR><TD ALIGN="LEFT"><B><FONT POINT-SIZE="10">Prerequisite Edge Description</FONT></B></TD></TR>
<TR><TD ALIGN="LEFT"><FONT POINT-SIZE="9" COLOR="gray35"><B>Description:</B></FONT><BR ALIGN="LEFT"/><FONT POINT-SIZE="9">Existing work on entailment‑tree generation in pure<BR ALIGN="LEFT"/>NLP, notably the EntailmentBank dataset and subsequent<BR ALIGN="LEFT"/>models that generate multi‑step logical trees from<BR ALIGN="LEFT"/>textual premises and a hypothesis.</FONT></TD></TR>
<TR><TD ALIGN="LEFT"><FONT POINT-SIZE="9" COLOR="gray35"><B>Explanation:</B></FONT><BR ALIGN="LEFT"/><FONT POINT-SIZE="9">The new multimodal task builds directly on the<BR ALIGN="LEFT"/>definition, data format, and evaluation concepts<BR ALIGN="LEFT"/>introduced by these prior works.</FONT></TD></TR>
<TR><TD ALIGN="LEFT"><FONT POINT-SIZE="10">strength: strong; depth: 1</FONT></TD></TR>
</TABLE>
>, shape=box, style="rounded,filled,dashed", color="gray60", fillcolor="#e8f4ea", fontname="Helvetica", margin="0.04,0.03"];
    "273641238.c1" -> "__edge_metadata_14" [dir=none, weight=3];
    "__edge_metadata_14" -> "248887255.c3" [weight=3];
    "__edge_metadata_15" [label=<
<TABLE BORDER="0" CELLBORDER="0" CELLPADDING="4">
<TR><TD ALIGN="LEFT"><B><FONT POINT-SIZE="10">Prerequisite Edge Description</FONT></B></TD></TR>
<TR><TD ALIGN="LEFT"><FONT POINT-SIZE="9" COLOR="gray35"><B>Description:</B></FONT><BR ALIGN="LEFT"/><FONT POINT-SIZE="9">Earlier methods that either linearise the tree and<BR ALIGN="LEFT"/>generate it in a single pass, or perform isolated<BR ALIGN="LEFT"/>single‑step reasoning without global feedback.</FONT></TD></TR>
<TR><TD ALIGN="LEFT"><FONT POINT-SIZE="9" COLOR="gray35"><B>Explanation:</B></FONT><BR ALIGN="LEFT"/><FONT POINT-SIZE="9">Motivate the need for a globally‑aware RL framework<BR ALIGN="LEFT"/>and inform design choices such as binary composition<BR ALIGN="LEFT"/>and the reward alignment.</FONT></TD></TR>
<TR><TD ALIGN="LEFT"><FONT POINT-SIZE="10">strength: strong; depth: 1</FONT></TD></TR>
</TABLE>
>, shape=box, style="rounded,filled,dashed", color="gray60", fillcolor="#e8f4ea", fontname="Helvetica", margin="0.04,0.03"];
    "253237103.c0" -> "__edge_metadata_15" [dir=none, weight=3];
