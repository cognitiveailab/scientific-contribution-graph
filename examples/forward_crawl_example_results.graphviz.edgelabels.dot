    "__edge_metadata_56" [label=<
<TABLE BORDER="0" CELLBORDER="0" CELLPADDING="4">
<TR><TD ALIGN="LEFT"><B><FONT POINT-SIZE="10">Prerequisite Edge Description</FONT></B></TD></TR>
<TR><TD ALIGN="LEFT"><FONT POINT-SIZE="9" COLOR="gray35"><B>Description:</B></FONT><BR ALIGN="LEFT"/><FONT POINT-SIZE="9">A representation of logical derivations as trees where<BR ALIGN="LEFT"/>atomic premises entail higher‑level conclusions,<BR ALIGN="LEFT"/>originally introduced for text‑only reasoning.</FONT></TD></TR>
<TR><TD ALIGN="LEFT"><FONT POINT-SIZE="9" COLOR="gray35"><B>Explanation:</B></FONT><BR ALIGN="LEFT"/><FONT POINT-SIZE="9">TV‑TREES extends this formalism to the multimodal<BR ALIGN="LEFT"/>domain, so the underlying definition is required.</FONT></TD></TR>
<TR><TD ALIGN="LEFT"><FONT POINT-SIZE="10">strength: strong; depth: 0</FONT></TD></TR>
</TABLE>
>, shape=box, style="rounded,filled,dashed", color="gray60", fillcolor="#e8f4ea", fontname="Helvetica", margin="0.04,0.03"];
