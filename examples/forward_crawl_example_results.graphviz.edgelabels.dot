    "__edge_metadata_69" [label=<
<TABLE BORDER="0" CELLBORDER="0" CELLPADDING="4">
<TR><TD ALIGN="LEFT"><B><FONT POINT-SIZE="10">Prerequisite Edge Description</FONT></B></TD></TR>
<TR><TD ALIGN="LEFT"><FONT POINT-SIZE="9" COLOR="gray35"><B>Description:</B></FONT><BR ALIGN="LEFT"/><FONT POINT-SIZE="9">A method for constructing hierarchical entailment<BR ALIGN="LEFT"/>trees that make the logical flow of natural‑language<BR ALIGN="LEFT"/>inference explicit, originally applied to open‑domain<BR ALIGN="LEFT"/>question answering.</FONT></TD></TR>
<TR><TD ALIGN="LEFT"><FONT POINT-SIZE="9" COLOR="gray35"><B>Explanation:</B></FONT><BR ALIGN="LEFT"/><FONT POINT-SIZE="9">The assistant’s explanation mechanism is modeled after<BR ALIGN="LEFT"/>entailment trees, extending them from NL inference to<BR ALIGN="LEFT"/>program‑level reasoning.</FONT></TD></TR>
<TR><TD ALIGN="LEFT"><FONT POINT-SIZE="10">strength: strong; depth: 0</FONT></TD></TR>
</TABLE>
>, shape=box, style="rounded,filled,dashed", color="gray60", fillcolor="#e8f4ea", fontname="Helvetica", margin="0.04,0.03"];
