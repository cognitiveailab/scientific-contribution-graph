    "__edge_metadata_20" [label=<
<TABLE BORDER="0" CELLBORDER="0" CELLPADDING="4">
<TR><TD ALIGN="LEFT"><B><FONT POINT-SIZE="10">Prerequisite Edge Description</FONT></B></TD></TR>
<TR><TD ALIGN="LEFT"><FONT POINT-SIZE="9" COLOR="gray35"><B>Description:</B></FONT><BR ALIGN="LEFT"/><FONT POINT-SIZE="9">Existing methods such as RLET, NLProofs, MetGen, and<BR ALIGN="LEFT"/>FLD that use single‑directional reasoning,<BR ALIGN="LEFT"/>reinforcement learning, or formal‑logic‑based rule<BR ALIGN="LEFT"/>generation for proof construction.</FONT></TD></TR>
<TR><TD ALIGN="LEFT"><FONT POINT-SIZE="9" COLOR="gray35"><B>Explanation:</B></FONT><BR ALIGN="LEFT"/><FONT POINT-SIZE="9">These works define the state of the art that FRVA<BR ALIGN="LEFT"/>improves upon and provide methodological inspiration<BR ALIGN="LEFT"/>(e.g., the need for verification, the use of stepwise<BR ALIGN="LEFT"/>generation).</FONT></TD></TR>
<TR><TD ALIGN="LEFT"><FONT POINT-SIZE="10">strength: strong; depth: 2</FONT></TD></TR>
</TABLE>
>, shape=box, style="rounded,filled,dashed", color="gray60", fillcolor="#e8f4ea", fontname="Helvetica", margin="0.04,0.03"];
