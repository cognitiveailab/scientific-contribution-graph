    "__edge_metadata_67" [label=<
<TABLE BORDER="0" CELLBORDER="0" CELLPADDING="4">
<TR><TD ALIGN="LEFT"><B><FONT POINT-SIZE="10">Prerequisite Edge Description</FONT></B></TD></TR>
<TR><TD ALIGN="LEFT"><FONT POINT-SIZE="9" COLOR="gray35"><B>Description:</B></FONT><BR ALIGN="LEFT"/><FONT POINT-SIZE="9">Research on textual entailment and explainable<BR ALIGN="LEFT"/>reasoning (e.g., entailment trees) provides methods<BR ALIGN="LEFT"/>for structuring premises and conclusions in natural<BR ALIGN="LEFT"/>language and for evaluating logical consistency of<BR ALIGN="LEFT"/>generated explanations.</FONT></TD></TR>
<TR><TD ALIGN="LEFT"><FONT POINT-SIZE="9" COLOR="gray35"><B>Explanation:</B></FONT><BR ALIGN="LEFT"/><FONT POINT-SIZE="9">The protocol requires annotators to produce statements<BR ALIGN="LEFT"/>that are immediate entailments of the code, a notion<BR ALIGN="LEFT"/>directly borrowed from the NL entailment literature.</FONT></TD></TR>
<TR><TD ALIGN="LEFT"><FONT POINT-SIZE="10">strength: strong; depth: 0</FONT></TD></TR>
</TABLE>
>, shape=box, style="rounded,filled,dashed", color="gray60", fillcolor="#e8f4ea", fontname="Helvetica", margin="0.04,0.03"];
