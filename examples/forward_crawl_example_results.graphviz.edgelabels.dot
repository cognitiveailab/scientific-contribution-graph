    "__edge_metadata_16" [label=<
<TABLE BORDER="0" CELLBORDER="0" CELLPADDING="4">
<TR><TD ALIGN="LEFT"><B><FONT POINT-SIZE="10">Prerequisite Edge Description</FONT></B></TD></TR>
<TR><TD ALIGN="LEFT"><FONT POINT-SIZE="9" COLOR="gray35"><B>Description:</B></FONT><BR ALIGN="LEFT"/><FONT POINT-SIZE="9">Earlier reinforcement‑learning approaches that use<BR ALIGN="LEFT"/>static reward structures for premise selection and<BR ALIGN="LEFT"/>tree construction.</FONT></TD></TR>
<TR><TD ALIGN="LEFT"><FONT POINT-SIZE="9" COLOR="gray35"><B>Explanation:</B></FONT><BR ALIGN="LEFT"/><FONT POINT-SIZE="9">NLDR builds upon and improves these prior methods;<BR ALIGN="LEFT"/>understanding their design informs the need for<BR ALIGN="LEFT"/>dynamic, logic‑based rewards.</FONT></TD></TR>
<TR><TD ALIGN="LEFT"><FONT POINT-SIZE="10">strength: strong; depth: 2</FONT></TD></TR>
</TABLE>
>, shape=box, style="rounded,filled,dashed", color="gray60", fillcolor="#e8f4ea", fontname="Helvetica", margin="0.04,0.03"];
    "280322203.c0" -> "__edge_metadata_16" [dir=none, weight=3];
    "__edge_metadata_16" -> "253237103.c0" [weight=3];
    "__edge_metadata_17" [label=<
<TABLE BORDER="0" CELLBORDER="0" CELLPADDING="4">
<TR><TD ALIGN="LEFT"><B><FONT POINT-SIZE="10">Prerequisite Edge Description</FONT></B></TD></TR>
<TR><TD ALIGN="LEFT"><FONT POINT-SIZE="9" COLOR="gray35"><B>Description:</B></FONT><BR ALIGN="LEFT"/><FONT POINT-SIZE="9">Earlier works applied reinforcement learning to select<BR ALIGN="LEFT"/>relevant premises when constructing entailment trees,<BR ALIGN="LEFT"/>demonstrating the feasibility of RL for this sub‑task.</FONT></TD></TR>
<TR><TD ALIGN="LEFT"><FONT POINT-SIZE="9" COLOR="gray35"><B>Explanation:</B></FONT><BR ALIGN="LEFT"/><FONT POINT-SIZE="9">The new joint action builds directly on the<BR ALIGN="LEFT"/>premise‑selection component introduced in these<BR ALIGN="LEFT"/>earlier RL systems.</FONT></TD></TR>
<TR><TD ALIGN="LEFT"><FONT POINT-SIZE="10">strength: strong; depth: 2</FONT></TD></TR>
</TABLE>
>, shape=box, style="rounded,filled,dashed", color="gray60", fillcolor="#e8f4ea", fontname="Helvetica", margin="0.04,0.03"];
