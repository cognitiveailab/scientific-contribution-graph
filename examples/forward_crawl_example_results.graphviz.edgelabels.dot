    "__edge_metadata_66" [label=<
<TABLE BORDER="0" CELLBORDER="0" CELLPADDING="4">
<TR><TD ALIGN="LEFT"><B><FONT POINT-SIZE="10">Prerequisite Edge Description</FONT></B></TD></TR>
<TR><TD ALIGN="LEFT"><FONT POINT-SIZE="9" COLOR="gray35"><B>Description:</B></FONT><BR ALIGN="LEFT"/><FONT POINT-SIZE="9">Prior work on collecting and structuring<BR ALIGN="LEFT"/>natural-language entailment data, including entailment<BR ALIGN="LEFT"/>trees and abductive reasoning over text.</FONT></TD></TR>
<TR><TD ALIGN="LEFT"><FONT POINT-SIZE="9" COLOR="gray35"><B>Explanation:</B></FONT><BR ALIGN="LEFT"/><FONT POINT-SIZE="9">The HTL annotation protocol draws on guidelines from<BR ALIGN="LEFT"/>Dalvi et al. (entailment trees) and Tafjord et al.<BR ALIGN="LEFT"/>(ProofWriter) to ensure that pre‑ and post‑conditions<BR ALIGN="LEFT"/>are immediate entailments of the highlighted code.</FONT></TD></TR>
<TR><TD ALIGN="LEFT"><FONT POINT-SIZE="10">strength: strong; depth: 0</FONT></TD></TR>
</TABLE>
>, shape=box, style="rounded,filled,dashed", color="gray60", fillcolor="#e8f4ea", fontname="Helvetica", margin="0.04,0.03"];
