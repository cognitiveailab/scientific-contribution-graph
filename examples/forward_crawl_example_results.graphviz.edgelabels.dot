    "__edge_metadata_36" [label=<
<TABLE BORDER="0" CELLBORDER="0" CELLPADDING="4">
<TR><TD ALIGN="LEFT"><B><FONT POINT-SIZE="10">Prerequisite Edge Description</FONT></B></TD></TR>
<TR><TD ALIGN="LEFT"><FONT POINT-SIZE="9" COLOR="gray35"><B>Description:</B></FONT><BR ALIGN="LEFT"/><FONT POINT-SIZE="9">A search‑based approach that constructs entailment<BR ALIGN="LEFT"/>trees by iteratively generating and validating<BR ALIGN="LEFT"/>deductive steps using learned heuristics.</FONT></TD></TR>
<TR><TD ALIGN="LEFT"><FONT POINT-SIZE="9" COLOR="gray35"><B>Explanation:</B></FONT><BR ALIGN="LEFT"/><FONT POINT-SIZE="9">The ENWN dataset is built to evaluate systems that use<BR ALIGN="LEFT"/>the same bidirectional search paradigm introduced in<BR ALIGN="LEFT"/>this prior work, making the methodology a prerequisite<BR ALIGN="LEFT"/>for its design and evaluation.</FONT></TD></TR>
<TR><TD ALIGN="LEFT"><FONT POINT-SIZE="10">strength: strong; depth: 1</FONT></TD></TR>
</TABLE>
>, shape=box, style="rounded,filled,dashed", color="gray60", fillcolor="#e8f4ea", fontname="Helvetica", margin="0.04,0.03"];
