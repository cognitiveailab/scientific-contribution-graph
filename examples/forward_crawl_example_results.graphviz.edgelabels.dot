    "__edge_metadata_70" [label=<
<TABLE BORDER="0" CELLBORDER="0" CELLPADDING="4">
<TR><TD ALIGN="LEFT"><B><FONT POINT-SIZE="10">Prerequisite Edge Description</FONT></B></TD></TR>
<TR><TD ALIGN="LEFT"><FONT POINT-SIZE="9" COLOR="gray35"><B>Description:</B></FONT><BR ALIGN="LEFT"/><FONT POINT-SIZE="9">An entailment tree encodes a hierarchical series of<BR ALIGN="LEFT"/>inference steps where each intermediate node is<BR ALIGN="LEFT"/>derived from its child sentences using a specific<BR ALIGN="LEFT"/>reasoning type; multi‑premise inference allows<BR ALIGN="LEFT"/>combining several premises in a single step.</FONT></TD></TR>
<TR><TD ALIGN="LEFT"><FONT POINT-SIZE="9" COLOR="gray35"><B>Explanation:</B></FONT><BR ALIGN="LEFT"/><FONT POINT-SIZE="9">CSEG requires models to generate such trees and to<BR ALIGN="LEFT"/>handle the six reasoning types defined for each<BR ALIGN="LEFT"/>inference step.</FONT></TD></TR>
<TR><TD ALIGN="LEFT"><FONT POINT-SIZE="10">strength: strong; depth: 0</FONT></TD></TR>
</TABLE>
>, shape=box, style="rounded,filled,dashed", color="gray60", fillcolor="#e8f4ea", fontname="Helvetica", margin="0.04,0.03"];
    "270766239.c0" -> "__edge_metadata_70" [dir=none, weight=3];
    "__edge_metadata_70" -> "233297051.c0" [weight=3];
    "__edge_metadata_71" [label=<
<TABLE BORDER="0" CELLBORDER="0" CELLPADDING="4">
<TR><TD ALIGN="LEFT"><B><FONT POINT-SIZE="10">Prerequisite Edge Description</FONT></B></TD></TR>
<TR><TD ALIGN="LEFT"><FONT POINT-SIZE="9" COLOR="gray35"><B>Description:</B></FONT><BR ALIGN="LEFT"/><FONT POINT-SIZE="9">The original task that requires models to generate a<BR ALIGN="LEFT"/>multi‑step entailment tree given a hypothesis and a<BR ALIGN="LEFT"/>set of candidate sentences.</FONT></TD></TR>
<TR><TD ALIGN="LEFT"><FONT POINT-SIZE="9" COLOR="gray35"><B>Explanation:</B></FONT><BR ALIGN="LEFT"/><FONT POINT-SIZE="9">Understanding the format of entailment trees and the<BR ALIGN="LEFT"/>generation requirements of SEG is necessary to create<BR ALIGN="LEFT"/>meaningful length‑ and shape‑based partitions for<BR ALIGN="LEFT"/>CSEG.</FONT></TD></TR>
<TR><TD ALIGN="LEFT"><FONT POINT-SIZE="10">strength: strong; depth: 0</FONT></TD></TR>
</TABLE>
>, shape=box, style="rounded,filled,dashed", color="gray60", fillcolor="#e8f4ea", fontname="Helvetica", margin="0.04,0.03"];
